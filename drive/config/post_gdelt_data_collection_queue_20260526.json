{
  "name": "Post-GDELT public data collection queue",
  "created_at": "2026-05-26",
  "notes": [
    "Runs after the Asia GDELT news-shock backfill finishes.",
    "No Refinitiv, LSEG, WRDS, Compustat, CRSP, or credential-gated sources.",
    "Commands are copy-only for Google Drive writes; no rclone sync/delete.",
    "Disabled tasks are catalog placeholders for sources that need a new scraper or API key."
  ],
  "tasks": [
    {
      "id": "public_macro_asia_market_sidecar",
      "title": "Refresh public macro, TWSE, Asia yfinance, sourced universes, entity mapping",
      "enabled": true,
      "credential_required": false,
      "priority": 10,
      "estimated_runtime": "20-90 minutes depending yfinance and Drive",
      "output_hint": "data_lake/public_macro_market_baseline, data_lake/markets/yfinance_asia, data_lake/official_disclosures/taiwan_twse, data_lake/entity_mapping/asia",
      "command": [
        "bash",
        "-lc",
        "SKIP_REDDIT_SYNC=1 MIN_FREE_GB=60 bash scripts/run_public_data_sidecar_20260525.sh"
      ]
    },
    {
      "id": "reddit_social_attention_ingest",
      "title": "Public Reddit/social attention daily ingest",
      "enabled": true,
      "credential_required": false,
      "priority": 20,
      "estimated_runtime": "20-90 minutes depending Reddit response and comment fetches",
      "output_hint": "data_lake/sentiment/reddit_ingest.sqlite, data_lake/sentiment/reddit/raw, data_lake/sentiment/reddit_daily_signals.parquet",
      "command": [
        "python3",
        "scripts/reddit_ingest_daily.py",
        "--fetch-modes",
        "new",
        "hot",
        "top:day",
        "top:week",
        "--limit",
        "100",
        "--max-pages",
        "4",
        "--sleep-secs",
        "1.2",
        "--stop-after-known",
        "40",
        "--comments-lookback-hours",
        "48",
        "--comments-max-posts",
        "80",
        "--comments-min-refetch-hours",
        "24",
        "--lookback-days",
        "45",
        "--min-upvotes",
        "3"
      ]
    },
    {
      "id": "reddit_social_attention_health",
      "title": "Build Reddit/social attention health report",
      "enabled": true,
      "credential_required": false,
      "priority": 30,
      "estimated_runtime": "under 2 minutes",
      "output_hint": "data_lake/sentiment/reddit_health.json, data_lake/sentiment/reddit_health.md",
      "command": [
        "python3",
        "scripts/reddit_data_health.py"
      ]
    },
    {
      "id": "reddit_social_attention_drive_copy",
      "title": "Copy Reddit/social attention outputs to Google Drive",
      "enabled": true,
      "credential_required": false,
      "priority": 40,
      "estimated_runtime": "5-30 minutes depending raw file count",
      "output_hint": "gdrive:Machine_Archive/molina_workbench/Sharpe-Renaissance-data/social_reddit",
      "command": [
        "bash",
        "scripts/sync_reddit_sentiment_drive.sh"
      ]
    },
