      "key_artifacts": ["exports/price_panel_clean.csv", "exports/mcap_panel_wide.csv"],
      "related": ["markets.crypto-landscape", "markets.ethereum-usdt"]
    },
    "markets.ethereum-usdt": {
      "topics": ["USDT", "Ethereum", "stablecoin flows", "on-chain", "FinTech"],
