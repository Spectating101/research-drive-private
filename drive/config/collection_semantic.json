{
  "version": 1,
  "summary": "Semantic metadata for models and procurement — merged into MODEL_GUIDE, partition READMEs, and collection_dictionary.",
  "domain_templates": {
    "markets": {
      "use_cases": ["price panels", "return studies", "cross-asset comparison", "universe construction"],
      "example_questions": [
        "What daily price history do we have for Asia equities?",
        "Where is the crypto token landscape snapshot?",
        "Can I get CoinGecko history for DeFi tokens?"
      ]
    },
    "news": {
      "use_cases": ["event studies", "news-risk overlays", "country shock panels", "headline research"],
      "example_questions": [
        "Where is the GDELT Asia news panel?",
        "How do I join news shocks to stock returns?"
      ]
    },
    "official": {
      "use_cases": ["authoritative filings", "exchange disclosures", "macro baselines", "governance research"],
      "example_questions": [
        "Where is TWSE official market data?",
        "Do we have Taiwan MOPS governance files?"
      ]
    },
    "reference": {
      "use_cases": ["entity resolution", "ticker mapping", "join keys before panel merges"],
      "example_questions": [
        "How do I map GDELT tickers to prices?",
        "Where is the SEC CIK lookup table?"
      ]
    },
    "social": {
      "use_cases": ["sentiment studies", "alt-data", "crypto-equity sentiment"],
      "example_questions": ["Where is the Reddit sentiment archive?"]
    },
    "catalog": {
      "use_cases": ["dataset discovery", "curated lists", "procurement search"],
      "example_questions": ["What datasets are in the curated index?"]
    },
    "acquired": {
      "use_cases": ["one-off downloads", "DOI collects", "chat procurement artifacts"],
      "example_questions": ["What did the desk download for me?", "Where is procured data for dataset X?"]
    },
    "derived": {
      "use_cases": ["reproducing internal notebooks", "analysis-ready merged panels", "saved trial outputs"],
      "example_questions": ["Where is the Asia news × market trial panel?"]
    },
    "ops": {
      "use_cases": ["operator visibility", "job manifests", "pipeline debugging"],
      "example_questions": ["What collection jobs ran recently?"]
    }
  },
  "partitions": {
    "news.gdelt-asia": {
      "topics": ["GDELT", "GKG", "Asia news", "country shocks", "event study"],
